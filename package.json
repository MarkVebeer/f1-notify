    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "i18n-iso-countries": "^7.14.0",
    "node-cron": "^3.0.3",
    "node-ical": "^0.16.1",
    "sqlite3": "^5.1.6",
    "tz-lookup": "^6.1.25"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
